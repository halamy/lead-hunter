# Lead Hunter Squad — Environment Variables
# Copy to .env and fill in your values
# Usage: source .env && python <script>.py

# ============================================================================
# SUPABASE (Required by ALL scripts)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ============================================================================
# GOOGLE MAPS API (Required by google-maps-scraper.py)
# ============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New) or Places API
# Free tier: $200/month credit
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================================
# ANTHROPIC / CLAUDE (Required by website-scraper.py, sentiment-classifier.py)
# ============================================================================
# Get from: https://console.anthropic.com/settings/keys
# Used for: LLM-based context extraction + sentiment classification
# Model: claude-haiku-4-5-20251001 (cost-effective for classification)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# EVOLUTION API (Required by whatsapp-api-client.py)
# ============================================================================
# Self-hosted: docker pull atendai/evolution-api
# Docs: https://doc.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=lead-hunter
